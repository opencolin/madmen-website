# Get these from app.crewai.com → your deployment → Status tab.
# The token is sensitive: rotate it if you ever committed it to a public repo.
CREWAI_ENTERPRISE_URL=https://your-crew-deployment.crewai.com
CREWAI_ENTERPRISE_TOKEN=your-bearer-token-here

# Legacy env names (from the original CrewAI Enterprise MCP server config) are
# also accepted — set either pair, not both.
# MCP_CREWAI_ENTERPRISE_SERVER_URL=
# MCP_CREWAI_ENTERPRISE_BEARER_TOKEN=

# Vercel AI Gateway key for image generation (Gemini Nano Banana via the
# google/gemini-2.5-flash-image and google/gemini-3-pro-image-preview models).
#
# Only required for LOCAL dev. On Vercel deploys this repo is already linked
# to the dablclub/madmen project — the AI Gateway authenticates via signed
# OIDC tokens automatically and the env var is not needed in production.
#
# Get a key from app.vercel.com → AI → Gateway → API Keys.
AI_GATEWAY_API_KEY=vck_...
